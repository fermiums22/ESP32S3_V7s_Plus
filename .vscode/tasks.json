{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ESPHome: setup",
            "type": "process",
            "command": "${workspaceFolder}\\setup_esphome.bat",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ESPHome: compile",
            "type": "process",
            "command": "${workspaceFolder}\\compile.bat",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ESPHome: factory flash USB",
            "type": "process",
            "command": "${workspaceFolder}\\factory_flash.bat",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ESPHome: OTA",
            "type": "process",
            "command": "${workspaceFolder}\\flash.bat",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ESPHome: logs",
            "type": "process",
            "command": "${workspaceFolder}\\logs.bat",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true,
                "focus": true
            }
        }
    ]
}
