{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ESPHome: setup",
            "type": "process",
            "command": "${workspaceFolder}\\setup_esphome.bat",
            "problemMatcher": [],
            "options": {
                "statusbar": {
                    "hide": true
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ESPHome: compile",
            "type": "process",
            "command": "${workspaceFolder}\\compile.bat",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "options": {
                "statusbar": {
                    "label": "$(tools) Build",
                    "detail": "Compile ESPHome firmware"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ESPHome: factory flash USB",
            "type": "process",
            "command": "${workspaceFolder}\\factory_flash.bat",
            "problemMatcher": [],
            "options": {
                "statusbar": {
                    "label": "$(circuit-board) Factory",
                    "detail": "Build and flash full factory image over USB"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ESPHome: upload",
            "type": "process",
            "command": "${workspaceFolder}\\flash.bat",
            "problemMatcher": [],
            "options": {
                "statusbar": {
                    "label": "$(cloud-upload) Upload",
                    "detail": "Upload the existing firmware"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ESPHome: logs",
            "type": "process",
            "command": "${workspaceFolder}\\logs.bat",
            "problemMatcher": [],
            "options": {
                "statusbar": {
                    "label": "$(terminal) Logs",
                    "detail": "Open ESPHome device logs"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true,
                "focus": true
            }
        }
    ]
}
